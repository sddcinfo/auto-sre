# Auto-SRE Environment Configuration

# Brave Search API key (for MCP web browsing)
# Get yours at: https://brave.com/search/api/
BRAVE_API_KEY=

# =============================================================================
# Model Configuration (optional - defaults to best option per backend)
# =============================================================================

# Ollama Backend (universal, requires >= 0.14.0)
# Alias           Model Tag                     Active Params  Size
# -----           ---------                     -------------  ----
# qwen3.5         qwen3.5:35b-a3b               3B             ~20 GB  (default)
# qwen3-coder     qwen3-coder:30b-a3b           3B             ~20 GB
# nemotron        nemotron-3-super              12B             ~87 GB
# deepseek-coder  deepseek-coder-v2:16b         16B             ~9 GB
#
# AUTOSRE_MODEL=qwen3.5

# llama.cpp Backend (llama-server, brew install llama.cpp)
# Alias           HuggingFace GGUF ID
# -----           -------------------
# qwen3.5         unsloth/Qwen3.5-35B-A3B-GGUF:Q4_K_M          (default)
# qwen3-coder     unsloth/Qwen3-Coder-30B-A3B-Instruct-GGUF:Q4_K_M
#
# AUTOSRE_MODEL=qwen3.5
